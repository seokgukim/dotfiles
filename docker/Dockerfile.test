# Dockerfile for Ubuntu 24.04 Dotfiles Validation
FROM ubuntu:24.04

# Avoid interactive prompts
ENV DEBIAN_FRONTEND=noninteractive

# Minimal bootstrap needed to run the legacy installer itself.
RUN apt-get update -y && \
    apt-get install -y \
    sudo \
    curl \
    jq \
    gnupg \
    ca-certificates \
    tar \
    xz-utils \
    && rm -rf /var/lib/apt/lists/*

ARG NVIM_RELEASE_API_URL=https://api.github.com/repos/neovim/neovim/releases/latest
RUN release_json="$(curl -fsSL "$NVIM_RELEASE_API_URL")" && \
    nvim_tarball_url="$(printf '%s' "$release_json" | jq -er '.assets[] | select(.name == "nvim-linux-x86_64.tar.gz") | .browser_download_url')" && \
    nvim_tarball_sha256="$(printf '%s' "$release_json" | jq -er '.assets[] | select(.name == "nvim-linux-x86_64.tar.gz") | .digest | select(startswith("sha256:")) | ltrimstr("sha256:")')" && \
    test -n "$nvim_tarball_url" && \
    test -n "$nvim_tarball_sha256" && \
    test "${#nvim_tarball_sha256}" -eq 64 && \
    curl -fsSL "$nvim_tarball_url" -o /tmp/nvim-linux-x86_64.tar.gz && \
    printf '%s  %s\n' "$nvim_tarball_sha256" /tmp/nvim-linux-x86_64.tar.gz | sha256sum -c - && \
    rm -rf /opt/nvim-linux-x86_64 && \
    tar -C /opt -xzf /tmp/nvim-linux-x86_64.tar.gz && \
    ln -sfn /opt/nvim-linux-x86_64/bin/nvim /usr/local/bin/nvim && \
    rm -f /tmp/nvim-linux-x86_64.tar.gz

# Set up user and grant sudo access
RUN useradd -ms /bin/bash kawi_test && \
    echo "kawi_test ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers
USER kawi_test
WORKDIR /home/kawi_test

# Copy dotfiles
COPY --chown=kawi_test:kawi_test . /home/kawi_test/dotfiles

# Run the legacy installer with a supported Neovim already on PATH, then verify
# the linked config exists.
WORKDIR /home/kawi_test/dotfiles
RUN chmod +x scripts/setup.sh && \
    sudo bash scripts/setup.sh && \
    test -L /home/kawi_test/.config/nvim && \
    test -L /home/kawi_test/.vimrc && \
    nvim --version | head -n 1

ENV LANG=en_US.UTF-8
ENV LANGUAGE=en_US:en
ENV LC_ALL=en_US.UTF-8

CMD ["/bin/bash"]
