# Dockerfile for Ubuntu 24.04 Dotfiles Validation
FROM ubuntu:24.04

# Avoid interactive prompts
ENV DEBIAN_FRONTEND=noninteractive

# Fix potential GPG/Time issues
RUN sed -i 's|http://archive.ubuntu.com/ubuntu/|http://mirror.kakao.com/ubuntu/|g' /etc/apt/sources.list.d/ubuntu.sources && \
    sed -i 's|http://security.ubuntu.com/ubuntu/|http://mirror.kakao.com/ubuntu/|g' /etc/apt/sources.list.d/ubuntu.sources

RUN apt-get update -y --allow-insecure-repositories && \
    apt-get install -y --allow-unauthenticated \
    git \
    curl \
    sudo \
    gnupg \
    ca-certificates \
    build-essential \
    software-properties-common \
    unzip \
    ripgrep \
    fd-find \
    locales \
    fonts-noto-cjk \
    language-pack-ko \
    language-pack-ja \
    && rm -rf /var/lib/apt/lists/*

# Set locale for CJK support
RUN locale-gen ko_KR.UTF-8 ja_JP.UTF-8
ENV LANG=ko_KR.UTF-8
ENV LANGUAGE=ko_KR:ko
ENV LC_ALL=ko_KR.UTF-8

# Install Neovim 0.11+ (using unstable PPA)
# Improved resilience for GPG issues
RUN add-apt-repository ppa:neovim-ppa/unstable -y && \
    apt-get update -y || true && \
    apt-get install -y neovim && \
    rm -rf /var/lib/apt/lists/*

# Set up user and grant sudo access
RUN useradd -ms /bin/bash kawi_test && \
    echo "kawi_test ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers
USER kawi_test
WORKDIR /home/kawi_test

# Copy dotfiles
COPY --chown=kawi_test:kawi_test . /home/kawi_test/dotfiles

# Run setup (simulating a fresh install)
# Note: setup.sh might need to be run without sudo in the container context
# or adjusted to skip interactive parts.
WORKDIR /home/kawi_test/dotfiles
RUN chmod +x setup.sh

CMD ["/bin/bash"]
